{
  "cases": [
    {
      "name": "Query 'wifi ' trailing space still shows Wi-Fi",
      "tags": ["trailing", "wifi"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "wifi " } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Wi-Fi" }
          }
        }
      ]
    },
    {
      "name": "Query 'zen ' trailing space expands Zen Browser actions",
      "tags": ["trailing", "zen", "desktop-actions"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "zen " } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "expanded": [{ "title": "Zen Browser" }],
            "rows": {
              "containsTitle": ["Zen Browser", "New Window"],
              "noneHighlightedExceptSelected": true
            }
          }
        }
      ]
    },
    {
      "name": "Query 'newxos ' and 'newxos' show same result when no children",
      "tags": ["trailing", "newxos", "stability"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "newxos " } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Newxos", "backend": "desktop-actions", "selectable": true }
          }
        }
      ]
    }
  ]
}
