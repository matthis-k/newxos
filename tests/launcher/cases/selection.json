{
  "cases": [
    {
      "name": "Audio group itself is not selectable",
      "tags": ["selection", "audio", "selectable"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "audio" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": {
              "backend": "desktop-actions",
              "selectable": true,
              "executable": true
            },
            "rows": {
              "contains": [
                { "title": "Volume", "backend": "desktop-actions", "selectable": true, "executable": true, "path": ["Actions", "Audio", "Volume"] },
                { "title": "Output Devices", "backend": "desktop-actions", "selectable": true, "executable": true, "path": ["Actions", "Audio", "Output Devices"] }
              ],
              "notContains": [
                { "title": "Audio", "selectable": true },
                { "title": "Audio", "selected": true },
                { "title": "Audio", "executable": true }
              ],
              "noneHighlightedExceptSelected": true
            }
          }
        }
      ]
    },
    {
      "name": "Audio children are selectable",
      "tags": ["selection", "audio"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "audio" } },
        {
          "expect": {
            "rows": {
              "contains": [
                { "title": "Output Devices", "selectable": true },
                { "title": "Volume", "selectable": true }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Exactly one selected for WiFi query",
      "tags": ["selection", "wifi"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "wifi" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Wi-Fi", "backend": "desktop-actions", "selectable": true }
          }
        }
      ]
    },
    {
      "name": "Exactly one selected for WiFi on",
      "tags": ["selection", "wifi", "action"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "wifi on" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "On", "backend": "desktop-actions", "selectable": true, "executable": true, "path": ["Actions", "Networking", "Wi-Fi", "On"] }
          }
        }
      ]
    },
    {
      "name": "Zen private window selects private action by title",
      "tags": ["selection", "zen", "action"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "zen priv" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Zen Browser (Private Window)", "backend": "desktop", "selectable": true, "executable": true },
            "invariants": ["exactly-one-selected"]
          }
        }
      ]
    },
    {
      "name": "Query 'a' does not expand Files from action title match",
      "tags": ["selection", "matching", "regression"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "a" } },
        {
          "expect": {
            "rows": {
              "notContainsTitle": ["New Window", "New Private Window"]
            }
          }
        }
      ]
    },
    {
      "name": "VPN shows promoted without visible Networking parent",
      "tags": ["vpn", "promotion"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "vpn" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "VPN", "backend": "desktop-actions", "selectable": true },
            "rows": {
              "notContains": [
                { "title": "Networking", "selected": true }
              ],
              "notContainsTitle": ["Germany", "Netherlands", "Fastest"],
              "noneHighlightedExceptSelected": true
            }
          }
        }
      ]
    }
  ]
}
