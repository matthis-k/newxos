{
  "cases": [
    {
      "name": "Audio group itself is not selectable",
      "tags": ["selection", "audio", "selectable"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "audio" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": {
              "backend": "desktop-actions",
              "selectable": true,
              "executable": true
            },
            "rows": {
              "contains": [
                { "title": "Volume", "backend": "desktop-actions", "selectable": true, "executable": true },
                { "title": "Output Devices", "backend": "desktop-actions", "selectable": true, "executable": true }
              ],
              "notContains": [
                { "title": "Audio", "selectable": false }
              ],
              "noneHighlightedExceptSelected": true
            }
          }
        }
      ]
    },
    {
      "name": "Audio children are selectable",
      "tags": ["selection", "audio"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "audio" } },
        {
          "expect": {
            "rows": {
              "contains": [
                { "title": "Output Devices", "selectable": true },
                { "title": "Volume", "selectable": true }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Exactly one selected for WiFi query",
      "tags": ["selection", "wifi"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "wifi" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Wi-Fi", "backend": "desktop-actions", "selectable": true }
          }
        }
      ]
    },
    {
      "name": "Exactly one selected for WiFi on",
      "tags": ["selection", "wifi", "action"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "wifi on" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "On", "backend": "desktop-actions", "selectable": true, "executable": true }
          }
        }
      ]
    },
    {
      "name": "VPN shows promoted without visible Networking parent",
      "tags": ["vpn", "promotion"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "vpn" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "VPN", "backend": "desktop-actions", "selectable": true },
            "rows": {
              "notContains": [
                { "title": "Networking", "selected": true }
              ],
              "noneHighlightedExceptSelected": true
            }
          }
        }
      ]
    }
  ]
}
