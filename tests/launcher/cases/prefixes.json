{
  "cases": [
    {
      "name": "Prefix ':' routes to action backend only",
      "tags": ["prefix"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": ":wifi" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Wi-Fi", "backend": "desktop-actions", "selectable": true },
            "rows": {
              "contains": [
                { "title": "Wi-Fi", "backend": "desktop-actions" }
              ],
              "notContains": [
                { "backend": "desktop" },
                { "backend": "files" },
                { "backend": "web" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Prefix ':wifi on' selects On action",
      "tags": ["prefix", "action"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": ":wifi on" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "On", "backend": "desktop-actions", "selectable": true, "executable": true },
            "rows": {
              "notContains": [
                { "backend": "desktop" },
                { "backend": "files" },
                { "backend": "web" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Prefix ':audio' shows audio children without non-action backends",
      "tags": ["prefix"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": ":audio" } },
        {
          "expect": {
            "rows": {
              "notContains": [
                { "backend": "desktop" },
                { "backend": "files" },
                { "backend": "web" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Prefix '@app' shows desktop app backend only",
      "tags": ["prefix", "apps"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "@app" } }
      ]
    },
    {
      "name": "Prefix '@apps zen' shows Zen in desktop backend only",
      "tags": ["prefix", "apps"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "@apps zen" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Zen Browser", "backend": "desktop", "selectable": true },
            "rows": {
              "notContains": [
                { "backend": "desktop-actions" },
                { "backend": "files" },
                { "backend": "web" }
              ]
            }
          }
        }
      ]
    }
  ]
}
