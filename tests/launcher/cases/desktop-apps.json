{
  "cases": [
    {
      "name": "Query 'zen' shows Zen Browser as promoted child",
      "tags": ["desktop", "zen"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "zen" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Zen Browser", "backend": "desktop", "selectable": true, "executable": true },
            "rows": {
              "contains": [
                { "title": "Zen Browser", "backend": "desktop", "selectable": true, "executable": true }
              ],
              "notContainsTitle": ["Files"],
              "noneHighlightedExceptSelected": true
            }
          }
        }
      ]
    },
    {
      "name": "Query 'zen priv' shows private window action",
      "tags": ["desktop", "zen"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "zen priv" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Zen Browser (Private Window)", "backend": "desktop", "selectable": true, "executable": true }
          }
        }
      ]
    },
    {
      "name": "Query 'zen' does not expand Files/Nautilus",
      "tags": ["desktop", "matching"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "zen" } },
        {
          "expect": {
            "rows": {
              "notContainsTitle": ["Files", "Nautilus"]
            }
          }
        }
      ]
    },
    {
      "name": "Query 'a' does not show desktop action child titles",
      "tags": ["desktop", "matching"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "a" } },
        {
          "expect": {
            "rows": {
              "notContainsTitle": ["New Window", "New Private Window", "Open Incognito Window"]
            }
          }
        }
      ]
    },
    {
      "name": "Query 'files' shows Files as selectable app",
      "tags": ["desktop", "files"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "files" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Files", "backend": "desktop", "selectable": true, "executable": true }
          }
        }
      ]
    },
    {
      "name": "Query 'new window' matches action by own title",
      "tags": ["desktop", "matching"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "new window" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "New Window", "backend": "desktop", "selectable": true, "executable": true }
          }
        }
      ]
    },
    {
      "name": "Query 'private' matches private action by own title",
      "tags": ["desktop", "matching"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "private" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "New Private Window", "backend": "desktop", "selectable": true, "executable": true },
            "rows": {
              "noneHighlightedExceptSelected": true
            }
          }
        }
      ]
    }
  ]
}
