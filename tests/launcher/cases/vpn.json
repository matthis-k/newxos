{
  "cases": [
    {
      "name": "Query 'vpn' keeps VPN as parent without expanding all destinations",
      "tags": ["vpn", "parent", "stability"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "vpn" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "VPN" },
            "rows": {
              "containsTitle": ["VPN"],
              "notContainsTitle": ["Germany", "Netherlands", "Fastest", "Algeria", "Georgia", "Uganda"],
              "noneHighlightedExceptSelected": true
            }
          }
        }
      ]
    },
    {
      "name": "Query 'vpn ' trailing space expands all VPN destinations",
      "tags": ["vpn", "trailing", "dynamic"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "vpn " } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "expanded": [{ "title": "VPN" }],
            "rows": {
              "containsTitle": ["VPN", "Germany", "Netherlands", "Fastest", "Algeria", "Georgia", "Uganda", "Norway"],
              "noneHighlightedExceptSelected": true
            }
          }
        }
      ]
    },
    {
      "name": "Query 'vpn g' shows all destinations matching g: Germany, Georgia, Uganda",
