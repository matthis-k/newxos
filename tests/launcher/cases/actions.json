{
  "cases": [
    {
      "name": "Query 'newxos' shows Newxos group",
      "tags": ["newxos", "group"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "newxos" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Newxos", "backend": "desktop-actions", "selectable": true },
            "rows": {
              "notContainsTitle": ["AI", "Switch System"]
            }
          }
        }
      ]
    },
    {
      "name": "Query 'newxos ' with trailing space browses children",
      "tags": ["newxos", "trailing-space"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "newxos " } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "rows": {
              "containsTitle": ["AI", "Switch System"]
            }
          }
        }
      ]
    },
    {
      "name": "Query 'newxos ai' selects AI action",
      "tags": ["newxos", "action"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "newxos ai" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "AI", "backend": "desktop-actions", "selectable": true, "executable": true }
          }
        }
      ]
    },
    {
      "name": "Query 'newxos switch' selects Switch System with risk",
      "tags": ["newxos", "action", "risk"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "newxos switch" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Switch System", "backend": "desktop-actions", "selectable": true, "executable": true }
          }
        }
      ]
    },
    {
      "name": "Query 'ai' promotes AI from Newxos group",
      "tags": ["newxos", "promotion"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "ai" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "AI", "backend": "desktop-actions", "selectable": true, "executable": true },
            "rows": {
              "notContains": [
                { "title": "Newxos", "selected": true }
              ],
              "noneHighlightedExceptSelected": true
            }
          }
        }
      ]
    },
    {
      "name": "Query 'switch' shows Switch System",
      "tags": ["newxos", "action"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "switch" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Switch System", "backend": "desktop-actions", "selectable": true, "executable": true }
          }
        }
      ]
    },
    {
      "name": "Query 'rebuild' also selects Switch System",
      "tags": ["newxos", "action"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "rebuild" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Switch System", "backend": "desktop-actions", "selectable": true, "executable": true }
          }
        }
      ]
    },
    {
      "name": "Query 'shutdown' shows Shut Down with risk gate",
      "tags": ["actions", "risk"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "shutdown" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Shut Down", "backend": "desktop-actions", "selectable": true, "executable": true },
            "rows": {
              "contains": [
                { "title": "Shut Down", "backend": "desktop-actions" }
              ]
            }
          }
        }
      ]
    }
  ]
}
