{
  "cases": [
    {
      "name": "Alt+Space toggles selected test switch",
      "tags": ["interaction", "alt", "switch", "toggle"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "test switch" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Test Switch", "selectable": true, "executable": true },
            "rows": {
              "noneHighlightedExceptSelected": true
            }
          }
        },
        { "do": { "type": "altInteract", "key": "space" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Test Switch" },
            "rows": {
              "noneHighlightedExceptSelected": true
            },
            "lastInteraction": {
              "ok": true,
              "mode": "switch-toggle",
              "success": true
            }
          }
        }
      ]
    },
    {
