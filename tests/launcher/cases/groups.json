{
  "cases": [
    {
      "name": "Networking group appears on 'network' query",
      "tags": ["groups", "networking"],
      "steps": [
        { "do": { "type": "reset" } },
        { "do": { "type": "open", "visible": false } },
        { "do": { "type": "setQuery", "query": "network" } },
        {
          "expect": {
            "exactlyOneSelected": true,
            "selected": { "title": "Networking", "backend": "desktop-actions", "selectable": true },
            "rows": {
              "containsTitle": ["Networking"]
            }
          }
        }
      ]
    },
    {
