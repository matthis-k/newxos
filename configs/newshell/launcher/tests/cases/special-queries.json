  },
  {
    "query": "= 1+2",
    "expect": "(.rows[0].title | test(\"3|= 1\\\\+2|1\\\\+2\")) and (.rows[0].placement == \"standalone\" or .rows[0].kind == \"calculator-result\")",
    "description": "calculator result should remain standalone"
  }
]
